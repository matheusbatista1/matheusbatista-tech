# ─────────────────────────────────────────────────────────────────────────────
# Public site
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Em prod: NEXT_PUBLIC_SITE_URL="https://matheusbatistadev.com"

# ─────────────────────────────────────────────────────────────────────────────
# Database (Postgres)
# Dev local: usar docker-compose (vide docker-compose.yml)
# Prod:      Neon Postgres (https://neon.tech) — free tier
#
# Em prod com Neon, anexe a query string:
#   ?sslmode=require&connect_timeout=15&pool_timeout=15
# Exemplo:
#   DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require&connect_timeout=15&pool_timeout=15"
#
# Por que:
# - connect_timeout=15 eleva o timeout default de conexao do Prisma (5s) para 15s,
#   absorvendo a latencia de cold-start do Neon (tipico 500-1000ms, p95 ~2.6s).
# - pool_timeout=15 eleva, de forma analoga, o timeout de aquisicao no pool de conexoes.
#
# Para o Postgres local via Docker estes parametros nao sao necessarios.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/matheusbatista_tech?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider (Google Gemini — free tier)
# Pegue sua API key gratis em https://aistudio.google.com (sem cartao de credito)
# Modelo padrao: gemini-2.5-flash (250 requests/dia free)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Rate limit (Upstash Redis — free tier 10k commands/dia)
# Crie em https://upstash.com (free, sem cartao)
# Em dev: pode deixar vazio — fallback noop sera ativado
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────────
# Auth (NextAuth v5 / Auth.js — Google OAuth + email allowlist)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Gere um secret: openssl rand -base64 32
AUTH_SECRET=""
#
# 2. Crie credenciais OAuth em https://console.cloud.google.com/apis/credentials
#    - Application type: Web application
#    - Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#    - Em prod, adicionar tambem: https://matheusbatistadev.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
#
# 3. Lista de emails permitidos no admin (comma-separated)
AUTH_ALLOWED_EMAILS="matheus.sbatista@outlook.com"
